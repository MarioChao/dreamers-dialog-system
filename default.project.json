{
  "name": "dreamers-dialog-system",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Modules": {
        "$path": "src/Packages",
        "$ignoreUnknownInstances": true,

        "DialogSystem": {
          "$path": "src/DialogSystem"
        }
      },

      "SoundEffects": {
        "$path": "src/TestPlace/ReplicatedStorage/SoundEffects",
        "$ignoreUnknownInstances": true
      }
    },

    "ServerScriptService": {
      "Scripts": {
        "$path": "src/TestPlace/ServerScriptService/Scripts",
        "$ignoreUnknownInstances": true
      }
    },

    "Workspace": {
      "_Instances": {
        "$path": "src/TestPlace/Workspace/_Instances",
        "$ignoreUnknownInstances": true
      }
    }
  },
  "globIgnorePaths": ["**/wally.toml"]
}