{
  "name": "dreamers-dialog-system",
  "tree": {
    "$className": "DataModel",

    "ReplicatedStorage": {
      "Modules": {
        "$path": "Packages",
        "$ignoreUnknownInstances": true,

        "DialogSystem": {
          "$path": "src/ReplicatedStorage/Modules/DialogSystem"
        }
      }
    },

    "ServerScriptService": {
      "DialogStorage": {
        "$path": "src/ServerScriptService/DialogStorage",
        "$ignoreUnknownInstances": true
      },
      "Scripts": {
        "$path": "src/ServerScriptService/Scripts",
        "$ignoreUnknownInstances": true
      }
    }
  },
  "globIgnorePaths": ["**/wally.toml"]
}